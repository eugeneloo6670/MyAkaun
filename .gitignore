# MyAkaun — git ignores
# Keep tracked: source code, configs, docs, schemas, lock files.
# Keep untracked: generated bytecode, dependencies, databases, logs, local env.

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version

# pytest / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# ---------------------------------------------------------------------------
# Node / JavaScript
# ---------------------------------------------------------------------------
node_modules/
.npm/
.yarn/
.pnp.*

# Vite / build outputs
dist/
dist-ssr/
*.local
.vite/

# ---------------------------------------------------------------------------
# Databases (local dev SQLite)
# ---------------------------------------------------------------------------
*.db
*.db-journal
*.sqlite
*.sqlite3
hermes_accounting.db

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------------------------------------------------------------------------
# Environment / secrets
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key

# ---------------------------------------------------------------------------
# Editor / OS
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# Hermes runtime
# ---------------------------------------------------------------------------
.hermes/
hermes_memory/
*.hermes.cache
